# ==========================================
# OPENAI API CONFIGURATION
# ==========================================
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-api-key-here

# Notes:
# - API key can also be set via admin interface at runtime
# - Estimated cost: $0.01-0.03 USD per meal plan generation
# - Model used: GPT-4-turbo (gpt-4-turbo-preview)

# ==========================================
# EMAIL CONFIGURATION
# ==========================================
# Email service provider (gmail, outlook, yahoo, etc.)
EMAIL_SERVICE=gmail

# Your email address
EMAIL_USER=your-email@gmail.com

# For Gmail: Use App Password, not your regular password
# Generate at: https://myaccount.google.com/apppasswords
EMAIL_PASSWORD=your-app-password-here

# Display name for outgoing emails
EMAIL_FROM_NAME=Keto Calculator

# Notes:
# - Gmail users MUST use an App Password (not regular password)
# - Enable 2FA on your Google account first
# - Then generate App Password at: https://myaccount.google.com/apppasswords
# - Email config can also be set via admin interface at runtime

# ==========================================
# SERVER CONFIGURATION
# ==========================================
PORT=3000
NODE_ENV=production

# ==========================================
# SESSION SECURITY
# ==========================================
# PÅKRÆVET i production! Generér med: openssl rand -base64 32
SESSION_SECRET=your-strong-random-secret-here
